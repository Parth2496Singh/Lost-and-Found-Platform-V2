@Library("Shared") _

pipeline {
    agent { label 'vinod' } 
    
    stages{
        stage("Pipeline_Begin"){
            steps{
                echo "🚀 Jenkins is now running directly on Vinod!"
            }
        }
        
        stage("Hello"){
            steps{
                script{
                    hello()
                }
            }
        }
        
        stage("Code"){
            steps{
                script{
                    clone("https://github.com/Parth2496Singh/Lost-and-Found-Platform-V2.git", "main")
                }
            }
        }
        
        stage("Build & Push"){
            steps{
                script{
                    build("django-jenkins", "latest")
                    dockerhub_push("django-jenkins", "latest", "parthsingh2496")
                }
            }
        }
        
        stage("Deploy to K8s") {
            steps {
                script {
                    withKubeConfig([credentialsId: 'k8s-secret']) {
                        sh "export http_proxy='' && export https_proxy='' && kubectl apply -f k8s/namespace.yml --insecure-skip-tls-verify"
                        sh "export http_proxy='' && export https_proxy='' && kubectl apply -f k8s/deployment.yaml --insecure-skip-tls-verify"
                        sh "export http_proxy='' && export https_proxy='' && kubectl apply -f k8s/service.yaml --insecure-skip-tls-verify"
                    }
                }
            }
        }
    }
}
