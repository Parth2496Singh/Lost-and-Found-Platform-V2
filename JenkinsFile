@Library("Shared") _

pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: ["sleep"]
    args: ["99d"]
  - name: kubectl
    image: bitnami/kubectl:latest
    command: ["sleep"]
    args: ["99d"]
'''
        }
    }
    
    stages {
        stage("Pipeline_Begin"){
            steps {
                echo "🚀 Jenkins is now running inside a dynamic Kubernetes Pod!"
            }
        }

        stage("Hello"){
            steps {
                script { hello() }
            }
        }

        stage("Code"){
            steps {
                // This runs in the default 'jnlp' container (the Jenkins agent)
                script {
                    clone("https://github.com/Parth2496Singh/Lost-and-Found-Platform-V2.git", "main")
                }
            }
        }

        stage("Build & Push"){
            steps {
                // Use Kaniko here if your library supports it, 
                // or ensure your library 'build' step points to a container that can build.
                container('kaniko') {
                    echo "🏗️ Building image using Kaniko..."
                    // script { build("django-jenkins", "latest") }
                }
            }
        }

        stage("Deploy to K8s") {
            steps {
                // SWITCH TO THE KUBECTL CONTAINER 🛰️
                container('kubectl') {
                    script {

                        sh "kubectl apply -f k8s/namespace.yml"
                        sh "kubectl apply -f k8s/deployment.yaml"
                        sh "kubectl apply -f k8s/service.yaml"
                    }
                }
            }
        }
    }
}
