@Library("Shared") _
pipeline {
    agent { label "vinod" }
    
    environment {
        // Dynamically create a SemVer tag using the Jenkins Build Number
        IMAGE_TAG = "v1.0.${env.BUILD_NUMBER}"

        SONAR_HOME = tool "Sonar" 
    }
    
    stages {
        stage("Pipeline_Begin") {
            steps {
                echo "Starting CI Pipeline for Build Number: ${env.IMAGE_TAG}"
            }
        }
        stage("Hello") {
            steps {
                script {
                    hello()
                }
            }
        }
        stage("Code") {
            steps {
                script {
                    clone("https://github.com/Parth2496Singh/Lost-and-Found-Platform-V2.git", "main")
                }
            }
        }
        stage("Trivy: Filesystem scan") {
            steps {
                script {
                    trivy_scan()
                }
            }
        }
        stage("OWASP: Dependency check") {
            steps {
                script {
                    owasp_dependency()
                }
            }
        }
        stage("SonarQube: Code Analysis") {
            steps {
                script {
                    sonarqube_analysis("Sonar", "lost-found-ultra", "lost-found-ultra")
                }
            }
        }
        stage("SonarQube: Code Quality Gates") {
            steps {
                script {
                    sonarqube_code_quality()
                }
            }
        }
        stage("Build") {
            steps {
                script {
                    build("lost-found-ultra", "${env.IMAGE_TAG}")
                }
            }
        }
        stage("Push to Dockerhub") {
            steps {
                script {
                    dockerhub_push("lost-found-ultra", "${env.IMAGE_TAG}", "parthsingh2496")
                }
            }
        }
    }
}
